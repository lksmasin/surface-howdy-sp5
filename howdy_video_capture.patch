+	def _stop_bridge(self):
+		"""Safely terminate the ir_bridge child process."""
+		proc = getattr(self, 'bridge_proc', None)
+		if proc is None:
+			return
+		try:
+			proc.terminate()
+			proc.wait(timeout=2)
+		except ProcessLookupError:
+			pass  # already dead
+		except subprocess.TimeoutExpired:
+			proc.kill()
+			proc.wait(timeout=1)
+		except Exception:
+			pass  # best-effort
